{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-8",
  "small_model": "anthropic/claude-sonnet-4-5",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b-64k": { "name": "Qwen3-Coder 30B (64k)" },
        "qwen3.6:27b": { "name": "Qwen3.6 27B" },
        "gemma4:26b": { "name": "Gemma 4 26B" }
      }
    }
  },
  "autoupdate": "notify",
  "share": "disabled",
  "instructions": ["~/.dotfiles/config/ai_coding_harness/AGENTS.md"],
  "plugin": [
    "@mohak34/opencode-notifier"
  ],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "webfetch": "ask",
    "bash": {
      "*": "ask",

      // Read-only shell utilities. Trailing space (not `cmd*`) is deliberate:
      // it forces a delimiter so a prefix can't match a longer command name
      // (e.g. `ps *` never matches `psql`, `comm *` never matches `command`).
      "cat *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "tail *": "allow",
      "pwd *": "allow",
      "which *": "allow",
      "type *": "allow",
      "whoami *": "allow",
      "hostname *": "allow",
      "uname *": "allow",
      "date *": "allow",
      "wc *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "comm *": "allow",
      "nl *": "allow",
      "column *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "realpath *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "tree *": "allow",
      "diff *": "allow",
      "cmp *": "allow",
      "du *": "allow",
      "df *": "allow",
      "ps *": "allow",
      "jq *": "allow",
      "bat *": "allow",
      "printenv *": "allow",
      "shasum *": "allow",
      "md5 *": "allow",

      // Accepted tradeoff: sed (GNU `e`/`s///e`), awk (system()/`print >`), and
      // sort (`-o` writes) can each run shell or write files, which these globs
      // cannot block. Allowed for convenience; writes are reversible under git.
      "sed *": "allow",
      "awk *": "allow",
      "sort *": "allow",

      // No trailing space so bare `git diff`/`git status` match too.
      "git diff*": "allow",
      "git log*": "allow",
      "git status*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git merge-base*": "allow",
      "git rev-parse*": "allow",
      "git rev-list*": "allow",
      "git shortlog*": "allow",
      "git describe*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git cat-file*": "allow",
      "git grep*": "allow",
      "git reflog*": "allow",
      "git stash list*": "allow",
      "git remote*": "allow",
      "git config --get*": "allow",
      "git config --list*": "allow",
      "git config -l*": "allow",

      // Local/read-only git ops for the worktree flow (ship-coding-change).
      // `git worktree remove` refuses to discard a dirty worktree without --force.
      "git fetch*": "allow",
      "git worktree*": "allow",
      "git add*": "allow",

      "gh pr view*": "allow",
      "gh pr diff*": "allow",
      "gh pr list*": "allow",
      "gh pr checks*": "allow",
      "gh pr status*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "gh search*": "allow",
      "gh run view*": "allow",
      "gh run list*": "allow",
      "gh repo view*": "allow",
      "gh workflow view*": "allow",
      "gh workflow list*": "allow",
      "gh release view*": "allow",
      "gh release list*": "allow",
      "gh label list*": "allow",
      "gh auth status*": "allow",

      // Potentially destructive and non-reversible.
      // find can -delete/-exec; fd can --exec/-X; rm is irreversible.
      "find *": "ask",
      "fd *": "ask",
      "rm *": "ask",
    },
    "external_directory": {
      "~/.dotfiles/config/claude/**": "allow",
      "~/.dotfiles/config/opencode/**": "allow",
      "~/.claude/**": "allow",
      "~/.config/opencode/**": "allow",
    }
  },
  "mcp": {
    "linear-server": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "rwx": {
      "type": "local",
      "command": ["rwx", "mcp", "serve"]
    }
  },
  "agent": {
    "generic-coding-changes-planner": {
      "description": "Generic planner for coding changes. Gathers context across Linear, GitHub, and the codebase, then produces an implementation plan covering architecture decisions, file changes, test strategy, risks, and tradeoffs. Use when the user asks to plan a code change before implementing, or when invoked as the parallel planner from the `plan-coding-changes` skill.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/planners/generic-coding-changes-planner.md}"
    },
    "coding-implementer": {
      "description": "Autonomously implements an already-approved coding plan inside a prepared git worktree — writes the code, runs the test suite, and iterates until the plan is satisfied or it hits a blocker. Returns a summary of what changed and the test status. Use when invoked by the ship-coding-change skill, or whenever a fully-specified plan and an existing worktree are handed off for hands-off implementation.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/implementers/coding-implementer.md}",
      "permission": {
        "bash": {
          // Test runners for the autonomous implement/verify phase.
          "bin/rspec*": "allow",
          "bundle exec rspec*": "allow",
          // Incremental atomic commits on the worktree branch (local, unpushed, reversible).
          "git commit*": "allow"
        }
      }
    },
    "architecture-reviewer": {
      "description": "Reviews code changes for architectural soundness. Focuses on layering, module boundaries, coupling, abstraction choices, and adherence to the codebase's architectural patterns (MVCQ, command/query split). Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/architecture-reviewer.md}"
    },
    "edge-case-reviewer": {
      "description": "Adversarial QA reviewer. Finds inputs, states, and scenarios that will break the changed code — nulls, empties, boundaries, races, failures, and surprising data shapes. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/edge-case-reviewer.md}"
    },
    "jose-reviewer": {
      "description": "Reviews code changes as Jose. Represents a specific reviewer with strong opinions — YAGNI, atomic changes, reference hygiene, and other personal preferences. Findings from this reviewer are weighted the highest in the panel and take precedence in the final verdict. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/jose-reviewer.md}"
    },
    "maintainability-reviewer": {
      "description": "Reviews code changes for long-term maintainability. Focuses on naming, duplication, clarity, structure, function length, and whether future readers will understand the code without archaeology. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/maintainability-reviewer.md}"
    },
    "performance-reviewer": {
      "description": "Reviews code changes for performance and scalability concerns. Focuses on N+1 queries, missing indexes, inefficient loops, caching opportunities, and work that will degrade as data grows. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/performance-reviewer.md}"
    },
    "product-manager-reviewer": {
      "description": "Reviews code changes from a product manager's perspective. Pulls the linked Linear issue(s) and checks whether the change delivers on the stated outcome, covers user-facing cases, and gets copy/voice right. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/product-manager-reviewer.md}"
    },
    "reviewer-orchestrator": {
      "description": "Runs a panel of eight specialized reviewers in parallel (architecture, maintainability, edge case, performance, security, senior engineer, product manager, and Jose) and consolidates their findings into a single prioritized report. Jose's findings are weighted highest. Use when you want a thorough multi-perspective review of a set of code changes.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/reviewer-orchestrator.md}"
    },
    "security-reviewer": {
      "description": "Reviews code changes for security vulnerabilities — injection, authentication, authorization, tenant isolation, data exposure, unsafe deserialization, secrets handling, CSRF/SSRF, and unsafe dependencies. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/security-reviewer.md}"
    },
    "senior-engineer-reviewer": {
      "description": "Holistic \"would I merge this?\" reviewer. Judges scope, restraint, whether the change actually solves the stated problem, and whether the tests meaningfully verify the behavior. Use as one reviewer in a multi-reviewer panel.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:~/.dotfiles/config/claude/agents/reviewers/senior-engineer-reviewer.md}"
    }
  }
}
