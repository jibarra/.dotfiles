{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-8",
  "small_model": "anthropic/claude-sonnet-4-5",
  "autoupdate": "notify",
  "share": "disabled",
  "instructions": ["~/.dotfiles/config/ai_coding_harness/AGENTS.md"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "webfetch": "allow",

    "cat *": "allow",
    "echo *": "allow",
    "find *": "allow",
    "grep *": "allow",
    "head *": "allow",
    "ls *": "allow",
    "rg *": "allow",
    "tail *": "allow",

    "git diff *": "allow",

     "bash": {
      "*": "ask",
    }
  }
}
