{
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "(Edit|MultiEdit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/joseibarra/.claude/hooks/lint-ruby-files.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
