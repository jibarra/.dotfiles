# Personal knowledge management — frictionless capture into the Obsidian
# vault. These only capture; they never invoke Claude.
#
# The vault is chosen by DOTFILES_ENV (set per machine in
# .machine_specific_zshrc), so the same short commands work on both machines.

case "$DOTFILES_ENV" in
  home) export VAULT="$HOME/Documents/jose/Documents/Notes/Vault" ;;
  work) export VAULT="$HOME/Documents/personal-knowledge-base" ;;
  *)    export VAULT="" ;;
esac

_pkm_dir() {
  [ -z "$VAULT" ] && { echo "no vault: DOTFILES_ENV is '${DOTFILES_ENV:-unset}'" >&2; return 1; }
  printf '%s' "$VAULT/knowledge-base/00-Inbox"
}

# t renew passport [due: 2026-08-01]
t() {
  local dir; dir=$(_pkm_dir) || return 1
  [ -z "$*" ] && { echo "usage: t <task>"; return 1; }
  printf -- "- [ ] %s [added: %s]\n" "$*" "$(date +%F)" >> "$dir/todos.md" && echo "-> todos.md"
}

# n pizza dough 65% hydration #til
n() {
  local dir; dir=$(_pkm_dir) || return 1
  [ -z "$*" ] && { echo "usage: n <note>"; return 1; }
  local ts slug file
  ts=$(date '+%F-%H%M%S')
  slug=$(printf '%s' "$*" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | tr -s '-' | sed 's/^-//; s/-$//' | cut -c1-40 | sed 's/-$//')
  [ -n "$slug" ] && file="$dir/$ts-$slug.md" || file="$dir/$ts.md"
  printf '%s\n' "$*" > "$file" && echo "-> ${file##*/}"
}

# open a Claude session in the vault
c() { cd "$VAULT" && claude; }

# one-shot focus query, e.g. tq "what should I do next"
tq() { (cd "$VAULT" && claude -p "/todo-focus $*"); }

# Quotes needed only if your text contains shell characters:
#   t "email Bob re: budget (A)"
# /todo-organize and /note-organize file captures later.
